# Environment Variables Template
# Copy this file to .env and fill in your values

# ===========================================
# AI GENERATION
# ===========================================

# Hugging Face API (optional, for higher quality)
# Get from: https://huggingface.co/settings/tokens
STABLE_DIFFUSION_API_KEY=

# Pollinations (free, no key needed)
POLLINATIONS_ENABLED=true

# ===========================================
# BLOCKCHAIN / NFT
# ===========================================

# Ethereum RPC (Infura, Alchemy, or public)
# Get from: https://app.infura.io/
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY

# Wallet private key (USE SEPARATE WALLET FOR MINTING!)
# Never use your main wallet with significant funds
WALLET_PRIVATE_KEY=

# OpenSea API Key (for listing)
# Get from: https://opensea.io/apikey
OPENSEA_API_KEY=

# Foundation API (optional, invite-only platform)
FOUNDATION_API_KEY=

# ===========================================
# IPFS STORAGE
# ===========================================

# Pinata IPFS (for NFT metadata storage)
# Get from: https://app.pinata.cloud/developers
PINATA_API_KEY=
PINATA_SECRET=

# ===========================================
# PRINT-ON-DEMAND
# ===========================================

# Printful API (for print fulfillment)
# Get from: https://www.printful.com/dashboard/api
PRINTFUL_API_KEY=

# Printify API (alternative to Printful)
# Get from: https://printify.com/app/settings/api
PRINTIFY_API_KEY=
PRINTIFY_SHOP_ID=

# Gelato API (global print network)
# Get from: https://gelato.com/developers
GELATO_API_KEY=

# ===========================================
# PAYMENTS (Stripe)
# ===========================================

# Stripe Secret Key
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe Webhook Secret (for subscription events)
STRIPE_WEBHOOK_SECRET=whsec_...

# ===========================================
# DATABASE (optional, for production)
# ===========================================

# MongoDB connection string
# Get from: https://cloud.mongodb.com/
MONGODB_URI=mongodb+srv://...

# ===========================================
# APP CONFIGURATION
# ===========================================

# Frontend URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API URL
API_URL=http://localhost:3001

# Environment
NODE_ENV=development

# Port
PORT=3001

# ===========================================
# ANALYTICS (optional)
# ===========================================

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry (error tracking)
SENTRY_DSN=

# ===========================================
# EMAIL (optional, for notifications)
# ===========================================

# SendGrid API
SENDGRID_API_KEY=

# Or SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
