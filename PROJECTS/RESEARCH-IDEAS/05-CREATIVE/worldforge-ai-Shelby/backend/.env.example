# WorldForge AI Backend Configuration

# Server
NODE_ENV=development
PORT=3001
HOST=localhost

# Database
DATABASE_URL=postgresql://worldforge:password@localhost:5432/worldforge
MONGODB_URI=mongodb://localhost:27017/worldforge
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# AI Services
OPENAI_API_KEY=your-openai-api-key
REPLICATE_API_TOKEN=your-replicate-token
STABLE_DIFFUSION_API_KEY=your-sd-api-key

# Storage
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
S3_BUCKET=worldforge-assets

# Payments
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Pricing
FREE_TIER_WORLDS=1
CREATOR_TIER_PRICE=1499
PUBLISHER_TIER_PRICE=4999
MARKETPLACE_FEE_PERCENT=5
WORLD_TEMPLATE_FEE_PERCENT=10

# WebSocket
WS_PORT=3002

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://worldforge.ai

# Logging
LOG_LEVEL=info
